<?xml version="1.0" encoding="UTF-8"?>
<inkscape-extension xmlns="http://www.inkscape.org/namespace/inkscape/extension">
    <name>Internet Resource...</name>
    <id>org.doctormo.import-clipart</id>
    <effect>
        <effects-menu>
            <submenu name="Import"/>
        </effects-menu>
        <object-type>all</object-type>
    </effect>
    <script>
        <command location="inx" interpreter="python">import_clipart.py</command>
    </script>
</inkscape-extension>
